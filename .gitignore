# Dependencies
node_modules/

# Build outputs
dist/
build/
# @retro-engine/build is a source package, not a build-output dir — track its
# source while keeping its own generated output ignored.
!packages/build/
packages/build/dist/
packages/build/node_modules/
.turbo/
*.tsbuildinfo

# Bun
bun.lockb
.bun/

# Tauri (Rust)
**/src-tauri/target/
**/src-tauri/gen/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Editor
.idea/
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Environment
.env
.env.local
.env.*.local

# Cache
.cache/
coverage/

# Playground dev-server saved projects (?mode=save output)
apps/playground/saved/

# Playwright MCP scratch output (screenshots, snapshots, console logs)
.playwright-mcp/
save-showcase.png

# MCP editor screenshots (scratch — delete before commit)
screenshots/
.screenshots/

# Playwright/export verification screenshots (root-level, transient)
/export-*.png

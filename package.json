{
  "name": "retro-engine",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "TypeScript game engine inspired by Bevy (ECS + WebGPU) with a Tauri+Bun studio.",
  "packageManager": "bun@1.3.14",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "dev": "turbo run dev",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "turbo run build && changeset publish",
    "prepare": "lefthook install"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.0",
    "@types/bun": "latest",
    "@webgpu/types": "latest",
    "lefthook": "^1.10.0",
    "oxlint": "latest",
    "turbo": "^2.3.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "bun": ">=1.3.0"
  }
}

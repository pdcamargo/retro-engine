{
  "name": "@retro-engine/build",
  "version": "0.1.0",
  "description": "Retro Engine export pipeline: export targets + the .rpak asset package format.",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "bin": {
    "retro-build": "./src/cli.ts"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./rpak": {
      "types": "./src/rpak.ts",
      "default": "./src/rpak.ts"
    }
  },
  "publishConfig": {
    "access": "restricted",
    "registry": "https://npm.pkg.github.com",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "./rpak": {
        "types": "./dist/rpak.d.ts",
        "default": "./dist/rpak.js"
      }
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "bench": "bun run bench/index.ts",
    "build": "tsc -p tsconfig.build.json",
    "lint": "oxlint .",
    "test": "bun test",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@retro-engine/assets": "workspace:*",
    "@retro-engine/project": "workspace:*"
  }
}

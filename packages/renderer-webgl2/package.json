{
  "name": "@retro-engine/renderer-webgl2",
  "version": "0.0.0",
  "description": "WebGL2 implementation of the Retro Engine renderer HAL. Stub — not implemented yet.",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./imgui": {
      "types": "./src/imgui-overlay.ts",
      "default": "./src/imgui-overlay.ts"
    }
  },
  "publishConfig": {
    "access": "restricted",
    "registry": "https://npm.pkg.github.com",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "./imgui": {
        "types": "./dist/imgui-overlay.d.ts",
        "default": "./dist/imgui-overlay.js"
      }
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "lint": "oxlint .",
    "test": "bun test",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@mori2003/jsimgui": "0.14.0",
    "@retro-engine/renderer-core": "workspace:*"
  }
}

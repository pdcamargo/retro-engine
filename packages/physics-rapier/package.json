{
  "name": "@retro-engine/physics-rapier",
  "version": "0.1.0",
  "description": "Rapier backend for Retro Engine physics (@dimforge/rapier2d-compat).",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "publishConfig": {
    "access": "restricted",
    "registry": "https://npm.pkg.github.com",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "lint": "oxlint .",
    "test": "bun test",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@dimforge/rapier2d-compat": "^0.14.0",
    "@dimforge/rapier3d-compat": "^0.14.0",
    "@retro-engine/ecs": "workspace:*",
    "@retro-engine/physics-core": "workspace:*"
  }
}

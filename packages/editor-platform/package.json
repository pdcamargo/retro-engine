{
  "name": "@retro-engine/editor-platform",
  "version": "0.1.0",
  "description": "Platform-host abstraction (preferences now; filesystem/dialogs later) for the studio. Browser-safe; the Tauri implementation lives in the app.",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "publishConfig": {
    "access": "restricted",
    "registry": "https://npm.pkg.github.com",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "lint": "oxlint .",
    "test": "bun test",
    "typecheck": "tsc --noEmit"
  }
}

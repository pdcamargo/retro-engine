{
  "name": "@retro-engine/reflect",
  "version": "0.1.0",
  "description": "Runtime type reflection for Retro Engine. A type registry keyed by stable name, a typed field-type vocabulary, and a JSON value codec for scene serialization.",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "publishConfig": {
    "access": "restricted",
    "registry": "https://npm.pkg.github.com",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "lint": "oxlint .",
    "test": "bun test",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@retro-engine/assets": "workspace:*",
    "@retro-engine/ecs": "workspace:*",
    "@retro-engine/math": "workspace:*",
    "wgpu-matrix": "^3.0.0"
  }
}

{
  "name": "@retro-engine/graph-editor",
  "version": "0.1.0",
  "description": "Reusable immediate-mode node-graph editing toolkit for the Retro Engine studio. Renders and edits any node graph (dataflow, exec-flow, state machines, context stacks, subgraphs) with typed pins, bezier wires, reroute weight-points, and embedded fields. Browser/webview-safe.",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "publishConfig": {
    "access": "restricted",
    "registry": "https://npm.pkg.github.com",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "bench": "bun run bench/index.ts",
    "build": "tsc -p tsconfig.build.json",
    "lint": "oxlint .",
    "test": "bun test",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@retro-engine/editor-sdk": "workspace:*",
    "@retro-engine/math": "workspace:*"
  }
}

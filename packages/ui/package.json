{
  "name": "@retro-engine/ui",
  "version": "0.0.0",
  "description": "Retained ECS-driven in-game UI (flexbox layout + Retro CSS) for Retro Engine.",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "publishConfig": {
    "access": "restricted",
    "registry": "https://npm.pkg.github.com",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "bench": "bun run bench/index.ts",
    "build": "tsc -p tsconfig.build.json",
    "lint": "oxlint .",
    "test": "bun test",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@retro-engine/ecs": "workspace:*",
    "@retro-engine/engine": "workspace:*",
    "@retro-engine/reflect": "workspace:*"
  }
}

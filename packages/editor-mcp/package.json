{
  "name": "@retro-engine/editor-mcp",
  "version": "0.0.0",
  "description": "Command registry + studio-side bridge for the Retro Engine MCP. Defines editor-control commands and connects the live studio to a studio-mcp-server relay. Browser/webview-safe.",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "publishConfig": {
    "access": "restricted",
    "registry": "https://npm.pkg.github.com",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "lint": "oxlint .",
    "test": "bun test",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@retro-engine/assets": "workspace:*",
    "@retro-engine/ecs": "workspace:*",
    "@retro-engine/editor-sdk": "workspace:*",
    "@retro-engine/engine": "workspace:*",
    "@retro-engine/gltf": "workspace:*",
    "@retro-engine/graph-editor": "workspace:*",
    "@retro-engine/mcp-protocol": "workspace:*",
    "@retro-engine/reflect": "workspace:*",
    "@retro-engine/renderer-core": "workspace:*"
  }
}

{
  "name": "@retro-engine/editor-sdk",
  "version": "0.1.0",
  "description": "Normalized, tokenized immediate-mode UI surface for building Retro Engine editors. Wraps Dear ImGui; consumers never touch the raw binding.",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "publishConfig": {
    "access": "restricted",
    "registry": "https://npm.pkg.github.com",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "lint": "oxlint .",
    "test": "bun test",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@mori2003/jsimgui": "0.14.0",
    "@retro-engine/ecs": "workspace:*",
    "@retro-engine/engine": "workspace:*",
    "@retro-engine/math": "workspace:*",
    "@retro-engine/reflect": "workspace:*",
    "@retro-engine/renderer-core": "workspace:*"
  }
}

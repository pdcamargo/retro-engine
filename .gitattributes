# Normalize line endings to LF in the repo regardless of platform.
* text=auto eol=lf

# Binary types — never convert.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.icns binary
*.woff binary
*.woff2 binary
*.ttf binary
*.otf binary
*.wasm binary

# Lockfiles stay LF.
bun.lock text eol=lf
Cargo.lock text eol=lf

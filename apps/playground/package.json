{
  "name": "@retro-engine/playground",
  "version": "0.0.1",
  "private": true,
  "description": "Browser-only smoke-test app that hosts the engine without Tauri. Used to validate end-to-end engine features quickly.",
  "type": "module",
  "scripts": {
    "dev": "bun --hot dev-server.ts",
    "build": "bun build index.html --outdir dist --minify --target=browser",
    "lint": "oxlint .",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@retro-engine/assets": "workspace:*",
    "@retro-engine/ecs": "workspace:*",
    "@retro-engine/editor-sdk": "workspace:*",
    "@retro-engine/engine": "workspace:*",
    "@retro-engine/gltf": "workspace:*",
    "@retro-engine/math": "workspace:*",
    "@retro-engine/reflect": "workspace:*",
    "@retro-engine/renderer-core": "workspace:*",
    "@retro-engine/renderer-webgpu": "workspace:*"
  },
  "devDependencies": {
    "@webgpu/types": "latest"
  }
}
